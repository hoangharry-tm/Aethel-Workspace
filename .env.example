# =============================================================================
# Aethel Workspace — Environment Variables
# Copy this file to .env and fill in values for local development.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=aethel_dev
POSTGRES_USER=aethel
POSTGRES_PASSWORD=changeme_dev_only

# -----------------------------------------------------------------------------
# Backend (aethel-core)
# -----------------------------------------------------------------------------
AETHEL_ENV=development

# Full DSN takes precedence over individual vars when set.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
AETHEL_DB_DSN=postgres://aethel:changeme_dev_only@localhost:5432/aethel_dev?sslmode=disable

# Used if AETHEL_DB_DSN is not set:
# AETHEL_DB_HOST=localhost
# AETHEL_DB_PORT=5432
# AETHEL_DB_NAME=aethel_dev
# AETHEL_DB_USER=aethel
AETHEL_DB_PASSWORD=changeme_dev_only

# JWT — generate with: openssl rand -base64 64
AETHEL_JWT_SECRET=REPLACE_WITH_RANDOM_64_BYTE_BASE64_STRING

# RSA private key path or inline PEM for RS256 tokens (optional — HS256 used if blank)
AETHEL_JWT_RSA_PRIVATE_KEY=

# SMTP (leave blank to disable email in development)
AETHEL_SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# Frontend (aethel-view)
# -----------------------------------------------------------------------------
NUXT_PUBLIC_API_BASE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Backup (optional — used by aethel-scripts/db-backup.sh)
# -----------------------------------------------------------------------------
# AETHEL_BACKUP_S3_BUCKET=my-aethel-backups
